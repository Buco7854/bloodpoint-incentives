# ============================================================
#  DBD Bloodpoint Incentive - configuration
#  Copy to .env and edit. Sensible defaults mean a minimal setup works.
# ============================================================

# ---- HTTP ----
PORT=3000
LOG_LEVEL=info
TZ=UTC

# ---- Site access (optional second auth layer, e.g. behind Authentik) ----
# If set, every route except /healthz requires this key
# (header below, or "Authorization: Bearer <key>").
# ACCESS_API_KEY=change-me
ACCESS_API_KEY_HEADER=X-API-Key

# ---- DBD authentication ----
# steam (default) or epic (stub, not implemented yet).
AUTH_PROVIDER=steam

# Quick mode: paste a pre-obtained DBD session key and the app polls immediately.
# This key expires; for unattended use prefer full Steam mode below.
# In quick mode you MUST also set DBD_GAME_VERSION (depot discovery is unavailable).
# DBD_API_KEY=

# Full Steam mode (preferred, unattended): headless Steam login, auto key refresh,
# and automatic version discovery. The account must own DBD (app id 381210).
# STEAM_USERNAME=
# STEAM_PASSWORD=
# STEAM_SHARED_SECRET=

# ---- Client / version ----
# Body platform: Windows (Steam) | EGS (Epic) | GRDK (MS Store).
DBD_PLATFORM=Windows

# 'auto' resolves the latest build from the Steam depot (full mode only).
# Pin a full version string to override; REQUIRED in quick mode. Example:
# DBD_GAME_VERSION=DBD_Sushi_REL_Steam_Shipping_9_3420587
DBD_GAME_VERSION=auto

VERSION_REFRESH_HOURS=6
DBD_CLIENT_VERSION=10.0.0
DBD_CLIENT_OS=10.0.26100.1.768.64bit

# ---- Behaviour ----
# Poll/show only one region with the single-server layout, e.g. eu-central-1.
# FORCE_REGION=

# Full-set refresh interval in seconds (clamped to >= 300, never below refreshTime).
POLL_INTERVAL_SECONDS=600
# Minimum gap between any two BHVR calls (anti-burst).
REQUEST_MIN_SPACING_MS=3000
# How often the browser re-reads the server cache.
UI_REFRESH_SECONDS=60
# Paginate above this many regions.
PAGE_SIZE=12

# ---- Persistence ----
# Directory for the small last-working-category state file.
STATE_DIR=./data
